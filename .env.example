# Mystic Tarot — copy this file to ".env" and fill in values.
# Sao chép file này thành ".env" rồi điền giá trị.

# Bắt buộc — API key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Tuỳ chọn — model Gemini (mặc định trong code: gemini-2.0-flash).
# Nếu free tier hết quota, thử một trong các giá trị sau rồi khởi động lại dev server:
# VITE_GEMINI_MODEL=gemini-2.5-flash
# VITE_GEMINI_MODEL=gemini-1.5-flash
